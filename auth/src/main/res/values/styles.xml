<?xml version='1.0' encoding='utf-8'?>
<resources><style name="auth_AccountCreation" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/auth_headerBlue</item>
        <item name="colorSecondary">@color/auth_headerBlue</item>
        <item name="colorAccent">#F00</item>
        <item name="android:windowBackground">#2E1C32</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="auth_HintText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="auth_TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="hintTextAppearance">@style/auth_HintText</item>
        <item name="android:textColor">@color/auth_white</item>
        <item name="android:textColorHint">@color/auth_white</item>
        <item name="colorControlNormal">@color/auth_white</item>
        <item name="colorControlActivated">@color/auth_white</item>
        <item name="colorControlHighlight">@color/auth_white</item>
        <item name="colorAccent">#FFFFFF</item>
    </style>

    <style name="auth_TextInputLayoutErrorAppearance" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">

    </style>

    </resources>
