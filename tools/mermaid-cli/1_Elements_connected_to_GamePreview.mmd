flowchart TD
    subgraph Screen["GamePreview screen"]
        GP["GamePreview<br/>@Composable"]
        GPVM["GamePreviewViewModel"]
        GAB["GameActionButtons"]
        GITEM["GameItem"]
        GSTATE["GameActionState"]
        GP_UI["GamePreviewUiState<br/>Loading | Data | NotFound | Error"]
        GP_EVT["GamePreviewEvent<br/>PlayGame | PurchaseSuccess | RequestNickName<br/>ShowRestartDialog | ShowError | OpenShop | OpenAppStore"]
        GP_ACT["GamePreviewAction<br/>OnPlay | OnDownload | OnUpdateGame | OnRestart<br/>OnDelete | OnBuy | OnBuyConfirm | OnAbortBuy"]
    end

    GP -->|collects| GP_UI
    GP -->|uses| GPVM
    GP -->|renders| GAB
    GAB -->|uses| GSTATE
    GSTATE -->|derived from| GITEM
    GITEM -->|built by| GPVM
    GP -->|handles| GP_EVT
    GAB -->|emits| GP_ACT
    GP_ACT -->|handled by| GPVM

    subgraph PreviewDeps["Injected into GamePreviewViewModel"]
        REPO1["GameRepository"]
        REPO2["ChapterRepository"]
        REPO3["PurchaseRepository"]
        REPO4["GameInstallRepository"]
        UC1["GetChaptersUseCase"]
        UC2["DownloadGameUseCase"]
        UC3["RestartGameUseCase"]
        UC4["SaveUserNickNameUseCase"]
        RES["MediaUrlResolver"]
        LOG["Logger"]
        TOAST["MakeToastService"]
        VER["AppVersionProvider"]
    end

    GPVM -->|observes catalog| REPO1
    GPVM -->|observes current chapter| REPO2
    GPVM -->|observes purchases| REPO3
    GPVM -->|observes install + download progress| REPO4
    GPVM -->|loads chapters| UC1
    GPVM -->|starts download| UC2
    GPVM -->|restarts game| UC3
    GPVM -->|saves nickname| UC4
    GPVM -->|resolves media urls| RES
    GPVM -->|logs errors| LOG
    GPVM -->|shows toasts| TOAST
    GPVM -->|compares minAppBuild| VER

    subgraph Outcome["Outcome"]
        ACT["SmsGameActivity"]
        ARGS["SmsGameActivityArgs<br/>chapterCode=currentChapter.normalizedCode"]
    end

    GP_EVT -->|PlayGame triggers| GP
    GP -->|calls onNavigateToGame| ACT
    ACT -->|created with| ARGS