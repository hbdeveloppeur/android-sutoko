<?xml version='1.0' encoding='utf-8'?>
<resources>

    <style name="SimpleStoryPreview" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="SmsGameActivity2" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="datepicker" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorPrimary">#471894</item>
        <item name="android:textColorPrimary">#471894</item>
        <item name="colorPrimaryDark">#2C80C8</item>
        <item name="colorAccent">#AC3030</item>
        <item name="android:datePickerStyle">@style/myDatePickerStyle</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/PositionButtonStyle</item>
    </style>

    <style name="myDatePickerStyle" parent="android:Widget.Material.DatePicker">
        <item name="android:datePickerMode">spinner</item>
        <item name="android:calendarTextColor">#643276</item>
    </style>


    <style name="NegativeButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#5E047F</item>
    </style>


    <style name="PositionButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#5E047F</item>
    </style>

    
    <style name="Load" parent="Theme.MaterialComponents.NoActionBar">

        
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <style name="Main" parent="Theme.MaterialComponents.NoActionBar">

        
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>

    <style name="StoryScreenshotPreview" parent="Theme.MaterialComponents.NoActionBar">

        
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>


    <style name="SmsGame" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">#141414</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowActivityTransitions">true</item>
    </style>

    <style name="ContactSupport" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/auth_headerBlue</item>
        <item name="colorSecondary">@color/auth_headerBlue</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="android:windowBackground">#202124</item>
        <item name="android:fitsSystemWindows">true</item>
        <item name="android:statusBarColor">#202124</item>
        <item name="android:navigationBarColor">#000</item>
    </style>

    <style name="StorySummary" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/auth_headerBlue</item>
        <item name="colorSecondary">@color/auth_headerBlue</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="android:windowBackground">#0c0e13</item>
        <item name="android:statusBarColor">#0c0e13</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="BillingProxy" parent="android:Theme.Translucent.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    
</resources>
