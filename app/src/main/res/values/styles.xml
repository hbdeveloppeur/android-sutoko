<?xml version='1.0' encoding='utf-8'?>
<resources>

    
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    
    <style name="SplashScreen" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">#F00</item>
        <item name="android:windowBackground">@color/black</item>
    </style>

    
    <style name="Main" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    
    <style name="StoryScreenshotPreview" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    
    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
    </style>

    <style name="BillingProxy" parent="android:Theme.Translucent.NoTitleBar" />

    
    <style name="SmsGame" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">#141414</item>
        <item name="android:fitsSystemWindows">false</item>
    </style>

    <style name="Theme.popup" parent="Widget.AppCompat.PopupMenu">
        <item name="android:textColor">#000</item>
        <item name="android:itemBackground">#D5CAE1</item>
        <item name="android:listPreferredItemHeightSmall">40dp</item>
    </style>


    
    <style name="Load" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    
    <style name="SimpleStoryPreview" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    
    <style name="SmsGameActivity2" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:windowBackground">@color/mainActivityBackgroundColor</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="HomeCardView" parent="@style/Widget.MaterialComponents.CardView">
        <item name="shapeAppearanceOverlay">@style/MaterialCardviewRoundedBottom</item>
    </style>

    <style name="MaterialCardviewRoundedBottom" parent="@style/Widget.MaterialComponents.CardView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
        <item name="cornerSizeBottomLeft">24dp</item>
    </style>

    <style name="MEditText" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorControlNormal">#8D1339</item>
        <item name="colorControlActivated">#8D1339</item>
        <item name="colorControlHighlight">#8D1339</item>
    </style>


    <style name="HintText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextInputLayoutAppearanceCustom" parent="Widget.Design.TextInputLayout">
        
        <item name="hintTextAppearance">@style/HintText</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="colorControlActivated">@color/white</item>
        <item name="colorControlHighlight">@color/white</item>
        <item name="colorAccent">#FFFFFF</item>
    </style>

    <style name="SCBSwitch" parent="Theme.AppCompat.Light">
        
        <item name="colorControlActivated">#D3286B</item>

        
        <item name="colorSwitchThumbNormal">#f1f1f1
        </item>

        
        <item name="android:colorForeground">#9EC7C7C7</item>
    </style>

    <style name="datepicker" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorPrimary">#6BB736</item>
        <item name="colorPrimaryDark">#2C80C8</item>
        <item name="colorAccent">#AC3030</item>
    </style>

    <style name="ContactSupport" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/headerBlue</item>
        <item name="colorSecondary">@color/headerBlue</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="android:windowBackground">#202124</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>


    <style name="StorySummary" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/headerBlue</item>
        <item name="colorSecondary">@color/headerBlue</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="android:windowBackground">#0c0e13</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="ErrorText" parent="TextAppearance.AppCompat">
        <item name="android:textColor">#FFF</item>
        <item name="android:textSize">14sp</item>
    </style>

    
    <style name="MainActivityBottomNavigationBar" parent="Theme.MaterialComponents">
        <item name="bottomNavigationStyle">@color/main_bottomNavigationStyle</item>
        <item name="colorPrimary">@color/main_colorPrimary</item>
        <item name="colorOnPrimary">@color/main_colorOnPrimary</item>
    </style>


    <style name="imageViewSquareStory" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>
